# Read by /release-ext. Schema documented in ~/.claude/commands/release-ext.md.

extension: mdparser
version_macro: PHP_MDPARSER_VERSION
version_file: php_mdparser.h
repo: iliaal/mdparser
build_matrix:
  - PHP-8.3
  - PHP-8.4
  - PHP-8.5
configure_base: "--enable-mdparser --enable-mdparser-dev"
smoke_test: scripts/pie-smoke.sh
windows_ci: true
